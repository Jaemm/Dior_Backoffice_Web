[{"/Users/bekzodchowis/Desktop/chowis/WEB_Dior_Backoffice/src/index.tsx":"1","/Users/bekzodchowis/Desktop/chowis/WEB_Dior_Backoffice/src/pages/ProductAttributes.js":"2","/Users/bekzodchowis/Desktop/chowis/WEB_Dior_Backoffice/src/auth/Logout.tsx":"3","/Users/bekzodchowis/Desktop/chowis/WEB_Dior_Backoffice/src/helpers/SchemaHelpers.ts":"4","/Users/bekzodchowis/Desktop/chowis/WEB_Dior_Backoffice/src/auth/Login.tsx":"5","/Users/bekzodchowis/Desktop/chowis/WEB_Dior_Backoffice/src/i18n/hooks.ts":"6","/Users/bekzodchowis/Desktop/chowis/WEB_Dior_Backoffice/src/components/UploadFormProduct.js":"7","/Users/bekzodchowis/Desktop/chowis/WEB_Dior_Backoffice/src/pages/MarketManagement.js":"8","/Users/bekzodchowis/Desktop/chowis/WEB_Dior_Backoffice/src/pages/StatisticReportDetail.js":"9","/Users/bekzodchowis/Desktop/chowis/WEB_Dior_Backoffice/src/components/EditProductCatalog.js":"10","/Users/bekzodchowis/Desktop/chowis/WEB_Dior_Backoffice/src/pages/UserManagement.js":"11","/Users/bekzodchowis/Desktop/chowis/WEB_Dior_Backoffice/src/reportWebVitals.ts":"12","/Users/bekzodchowis/Desktop/chowis/WEB_Dior_Backoffice/src/i18n/config.ts":"13","/Users/bekzodchowis/Desktop/chowis/WEB_Dior_Backoffice/src/pages/AnalysisDetails.tsx":"14","/Users/bekzodchowis/Desktop/chowis/WEB_Dior_Backoffice/src/pages/CustomerRecord.tsx":"15","/Users/bekzodchowis/Desktop/chowis/WEB_Dior_Backoffice/src/pages/StatisticsAndReportsDetailPage.tsx":"16","/Users/bekzodchowis/Desktop/chowis/WEB_Dior_Backoffice/src/helpers/URLHelpers.ts":"17","/Users/bekzodchowis/Desktop/chowis/WEB_Dior_Backoffice/src/auth/data/LoginAPI.ts":"18","/Users/bekzodchowis/Desktop/chowis/WEB_Dior_Backoffice/src/components/Sidebar.tsx":"19","/Users/bekzodchowis/Desktop/chowis/WEB_Dior_Backoffice/src/pages/AssignedCustomers.js":"20","/Users/bekzodchowis/Desktop/chowis/WEB_Dior_Backoffice/src/pages/ProductCatalog.js":"21","/Users/bekzodchowis/Desktop/chowis/WEB_Dior_Backoffice/src/components/NewDataTable.js":"22","/Users/bekzodchowis/Desktop/ch