tomer_uv_index} */}\n              </Typography>\n            </Grid>\n          </Grid>\n        </Box>\n      </Paper>\n\n      <Box marginBottom={1} marginTop={4}>\n        <Typography>\n          <b>Moisture Information</b>\n        </Typography>\n      </Box>\n\n      <Grid item xs>\n        <TableWrapper\n          style={{\n            maxHeight: \"100%\",\n            overflowX: \"initial\",\n            position: \"relative\",\n          }}\n          // isLoading={results.isValidating}\n        >\n        <Table size=\"small\" aria-label=\"simple table\">\n          <TableHead>\n            <TableRow>\n              <TableCell colSpan={12} size=\"medium\">Measurement</TableCell>\n              <TableCell align=\"left\" colSpan={12} size=\"medium\">T Zone Score</TableCell>\n              <TableCell align=\"left\" colSpan={12} size=\"medium\">U Zone Score</TableCell>\n              <TableCell align=\"left\" colSpan={12} size=\"medium\">T Zone Raw Value</TableCell>\n              <TableCell align=\"left\" colSpan={12} size=\"medium\">U Zone Raw Value</TableCell>\n              <TableCell align=\"left\" colSpan={12} size=\"medium\">Image</TableCell>\n            </TableRow>\n          </TableHead>\n          <TableBody>\n            {hydrationSebumData.map((row) => (\n              <TableRow\n                key={row.measurement}\n              >\n                <TableCell component=\"th\" scope=\"row\" colSpan={12} size=\"medium\">\n                  {row.measurement}\n                </TableCell>\n                <TableCell align=\"left\" colSpan={12} size=\"medium\">{row.t_score}</TableCell>\n                <TableCell align=\"left\" colSpan={12} size=\"medium\">{row.u_score}</TableCell>\n                <TableCell align=\"left\" colSpan={12} size=\"medium\">{row.t_raw_score}</TableCell>\n                <TableCell align=\"left\" colSpan={12} size=\"medium\">{row.u_raw_score}</TableCell>\n                <TableCell align=\"left\" colSpan={12} size=\"medium